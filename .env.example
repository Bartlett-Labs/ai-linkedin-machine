# ============================================================
# AI LinkedIn Machine - Environment Variables
# Copy to .env and fill in your actual values
# ============================================================

# ---- Claude via Bedrock Proxy (RECOMMENDED - uses your existing Anker gateway) ----
ANTHROPIC_BEDROCK_BASE_URL=https://your-bedrock-proxy-url.com/bedrock
ANTHROPIC_AUTH_TOKEN=your_auth_token_here
# CLAUDE_MODEL=global.anthropic.claude-opus-4-6-v1:0

# ---- Claude via Standard AWS Bedrock (alternative) ----
# If using direct AWS Bedrock with IAM credentials instead of a proxy:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_SESSION_TOKEN=your_session_token
# CLAUDE_MODEL=us.anthropic.claude-opus-4-6-20250610-v1:0

# ---- Claude via Direct Anthropic API (alternative) ----
# If you don't use Bedrock at all:
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-6-20250610

# OpenAI API Key (FALLBACK ONLY - used if Anthropic is unavailable)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.2

# Google Sheets Integration
# The ID from the Sheet URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
GOOGLE_SHEET_ID=your_sheet_id_here
# Path to Google service account JSON (or use GOOGLE_TOKEN_PATH for OAuth)
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json
# GOOGLE_TOKEN_PATH=credentials/token.json

# LinkedIn API (for API-based post creation)
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# Browser settings
HEADLESS=true
SESSION_DIR=~/.ai-linkedin-machine/sessions

# ElevenLabs (voice follow-up for new connections)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here

# Dashboard API (optional — if not set, auth is disabled in dev mode)
# DASHBOARD_API_KEY=your_api_key_here
